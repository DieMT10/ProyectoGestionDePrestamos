<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">
    <TextView android:id="@+id/tv_articulo_historial" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textStyle="bold" />
    <TextView android:id="@+id/tv_persona_historial" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <TextView android:id="@+id/tv_fecha_prestamo_historial" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <TextView android:id="@+id/tv_fecha_estimada_historial" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    <TextView android:id="@+id/tv_fecha_real_historial" android:layout_width="wrap_content" android:layout_height="wrap_content" />
</LinearLayout>